      "path": "/?action=ad-revenge",
      "expectedStatus": 400,
      "expectedBody": {"error": "player_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Referral info — missing player_id",
      "method": "GET",
      "path": "/?action=referral-info",
      "expectedStatus": 400,
      "expectedBody": {"error": "player_id required"},
